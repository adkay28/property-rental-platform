<% layout("layouts/boilerplate.ejs") %>

  <div class="row mt-3">

    <div class="col-8 offset-3">
      <h2>
        <%= listing.title %>
      </h2>
    </div>

    <div class="col-6 offset-3">
      <div class="card listing-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_img" />
        <div class="card-body">
          <div class="card-text">
          <p class="card-text">Owned by : <%= listing.owner.username %>
          </p>
          <%= listing.description %> <br /> <br />
            <p>Price: &#8377;<%= listing.price.toLocaleString("en-IN") %>/night</p>
            <p>Location: <%= listing.location %></p>
            <p>Country : <%= listing.country %></p>
        </div>
      </div>
    </div>

      <% if((currUser) && (currUser._id.equals(listing.owner._id))) { %>
        <div class="btns mt-3 d-flex justify-content-center gap-3">
          <a class="btn btn-dark add-btn px-4" href="/listings/<%= listing._id %>/edit">Edit</a>

          <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" class="m-0">
            <button class="btn btn-danger px-4">Delete</button>
          </form>
        </div>
      <% } %>

    </div>
    
    <div class="col-8 offset-2 mb-3">
      <br />
      <hr />
      <br />

      <div class="reviewDiv">
        <% if(currUser) {%>
          <div class="addReview">
            <h4>Add a Review</h4>
            <form method="POST" action="/listings/<%=listing._id%>/reviews" novalidate class="needs-validation mb-3">

              <div class="mb-3 mt-3">
                <label for="review[rating]" class="form-label mt-3">Rating</label>
                <fieldset class="starability-basic">
                  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked
                    aria-label="No rating." />
                  <input type="radio" id="first-rate1" name="review[rating]"
                    value="1" />
                  <label for="first-rate1" title="Terrible">1 star</label>
                  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                  <label for="first-rate2" title="Not good">2stars</label>
                  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                  <label for="first-rate3" title="Average">3 stars</label>
                  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
              </div>

              <label for="body" class="form-label">Your Review</label>
              <textarea placeholder="Write here" name="review[body]" class="form-control" rows="7" required></textarea>
              <div class="invalid-feedback">Please enter review</div>

              <br />
              <br />
              <button class="btn btn-outline-dark col-2 offset-5">Submit</button>
            </form>

            <br />
            <hr />
        <% } %>
          </div>

          <% if(listing.reviews.length) { %>
            <h4 class="mb-5">All Reviews</h4>
            <div class="row">
              <% for(let rev of listing.reviews) { %>
                <div class="card mt-2 mb-2 col-5 ms-5">
                  <h5 class="card-title mt-2">@<%= rev.author.username %>
                  </h5>
                  <p class="card-text mt-3">
                    <%= rev.body %>
                  </p>
                  <p class="card-text mb-3">Rating: <%= rev.rating %> stars</p>
                  <p class="starability-result" data-rating="<%=rev.rating%>"></p>
                  <%if((currUser) && (currUser._id.equals(rev.author._id))) {%>
                    <form class="mt-3" method="POST"
                      action="/listings/<%= listing._id %>/reviews/<%= rev._id %>?_method=DELETE">
                      <button class="btn btn-sm btn-danger mb-3">Delete</button>
                    </form>
                  <% } %>
                </div>
              <% } %>
            </div>
            <br />
            <hr />
            <br />
          <% } %>
      </div>
    </div>
  </div>

  <div class="row mb-5"> 
    <div class="col-8 offset-2">
      <h4 class="mb-3">Where you'll be</h4>
      <div id="map" style="height: 400px; width: 100%; border-radius: 10px; z-index: 1;"></div>
    </div>
  </div>


  <script>
    window.addEventListener('load', () => {
        const mapToken = '<%= MAP_API_KEY %>'; 
        const coordinates = JSON.parse('<%- JSON.stringify(listing.geometry ? listing.geometry.coordinates : [77.2090, 27.1751]) %>');
        const latLng = [coordinates[1], coordinates[0]];

        // Added scrollWheelZoom option and removed the redundant zoom
        const map = L.map('map', {
          scrollWheelZoom : false
        }).setView(latLng, 14);

        L.tileLayer(`https://api.maptiler.com/maps/streets-v2/{z}/{x}/{y}.png?key=${mapToken}`, {
            attribution: 'MapTiler & OpenStreetMap',
        }).addTo(map);

        L.marker(latLng).addTo(map)
            .bindPopup("<b><%= listing.title %></b>")
            .openPopup();
        
        setTimeout(() => {
            map.invalidateSize();
        }, 100);
    });
</script>