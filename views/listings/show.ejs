<% layout("layouts/boilerplate.ejs") %>

<div class="row mt-3">
  
  <div class="col-8 offset-3">
    <h2><%= listing.title %></h2>
  </div>

  <div class="col-6 offset-3">
    <div class="card">
      <img
        src="<%= listing.image %>"
        class="card-img-top show-img"
        alt="listing_img"
      />
      <div class="card-body">
        <p class="card-text">
          <%= listing.description %> <br />
          &#8377;<%= listing.price.toLocaleString("en-IN") %> <br />
          <%= listing.location %> <br />
          <%= listing.country %>
        </p>
      </div>
    </div>

    <div class="btns mt-3">
      <a class="btn btn-dark col-2 add-btn" href="/listings/<%= listing._id %>/edit">Edit</a>

      <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" class="d-inline">
        <button class="btn btn-danger col-2 offset-1">Delete</button>
      </form>
    </div>
  </div> <div class="col-8 offset-3 mb-3">
    <br />
    <hr />
    <br />

    <div class="reviewDiv">
      <h4>Add a Review</h4>
      <form
        method="POST"
        action="/listings/<%=listing._id%>/reviews"
        novalidate
        class="needs-validation mb-3"
      >
        <label for="body" class="form-label">Your Review</label>
        <textarea
          placeholder="Write here"
          name="review[body]"
          class="form-control"
          rows="7"
          required
        ></textarea>
        <div class="invalid-feedback">Please enter review</div>
        
        <br />
        
        <label for="rating" class="form-label">Rating*</label>
        <input
          type="number"
          name="review[rating]"
          min="1"
          max="5"
          class="form-control mb-3"
          required
        />
        <div class="invalid-feedback">Please enter rating between 1-5</div>
        
        <br />
        <button class="btn btn-outline-dark col-2 offset-5">Submit</button>
      </form>
      
      <br />
      <hr />
      <br />
      
      <!-- displaying all the reviews -->
      <h4>All Reviews</h4>
      <div class="row">
        <% for(let rev of listing.reviews) { %>
            <div class="card mt-2 mb-2 col-5 ms-3">
                <h5 class="card-title mt-2">NAME</h5>
                <p class="card-text"><%= rev.body %></p>
                <p class="card-text">Rating: <%= rev.rating %> stars</p>
                <form class="mt-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= rev._id %>?_method=DELETE">
                    <button class="btn btn-sm btn-danger mb-3">Delete</button>
                </form>
            </div>
        <% } %>
      </div>
    </div>
  </div> </div>