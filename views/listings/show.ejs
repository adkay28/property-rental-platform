<% layout("layouts/boilerplate.ejs") %>

<div class="row mt-3">
    <div class="col-8 offset-3">
        <h2><%= listing.title %></h2>
    </div>

    <div class="col-6 offset-3">
        <div class="card">
            <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing_img">
            <div class="card-body">
                <p class="card-text">
                    <%= listing.description %> <br>
                    &#8377;<%= listing.price.toLocaleString("en-IN") %> <br>
                    <%= listing.location %> <br>
                    <%= listing.country %>
                </p>
            </div>
        </div>

        <div class="btns mt-3">
            <a class="btn btn-dark col-2 add-btn" href="/listings/<%= listing._id %>/edit">Edit</a>
            
            <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" class="d-inline">
                <button class="btn btn-danger col-2 offset-1">Delete</button>
            </form>
        </div>
    </div>
</div>