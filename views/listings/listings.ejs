<% layout("layouts/boilerplate.ejs") %>
<body>
    <h1>All Listings</h1>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 row-cols-xs-1">
        <% for(let listing of allListings) { %>
            <div class="listing-card card col" style="width: 20rem;">
                <img src="<%= listing.image %>" class="card-img-top" alt="listing_image" style="height: 20rem"/>
                <div class="card-img-overlay"></div>
                <div class="card-body">
                    <a href="/listings/<%= listing._id %>" class="stretched-link text-dark text-decoration-none">
                        <b><%= listing.title %></b>
                    </a>
                    <p><b>&#8377; <%= listing.price %></b>/night</p>
                </div>
            </div>
        <% } %>
    </div>
</body>
