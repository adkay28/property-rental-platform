<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust - Edit your Listing</title>
</head>
<body>
    <h2>Edit Listing</h2>
    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
        <input name="title" value="<%= listing.title%>" type="text">    <br><br>
        <textarea name="description" type="text"> <%=listing.description%> </textarea>  <br><br>
        <input name="price" value=<%= listing.price%> type="number">    <br><br>
        <input name="image" value="<%= listing.image%>" type="text">  <br><br>
        <input name="location" value="<%= listing.location%>" type="text">  <br><br>
        <input name="country" value="<%= listing.country%>" type="text">  <br><br>
        <button>Submit</button>
    </form>
</body>
</html>